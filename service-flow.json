                                                                              ],
                                                                              [
                                                                                  "引导入座/取餐",
                                                                                  "引导顾客至用餐区域或外卖订单取餐点"
                                                                              ],
                                                                              [
                                                                                  "询问需求",
                                                                                  "询问顾客是否需要帮助，如提供菜单、解答问题等"
