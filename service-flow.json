                                             "content":  [
                                                             {
                                                                 "type":  "bullet",
                                                                 "items":  [
                                                                               "能回答基础问题：「这个能加热吗？」→「可以微波炉 5 秒，不同的风味」",
                                                                               "「里面有什么食材？」→ 准确说出配料",
                                                                               "不说「我不知道」，而是「我帮您确认一下」"
                                                                           ]
                                                             }
                                                         ]
                                         }
                                     ]
                    },
                    {
                        "id":  "module-2",
                        "num":  2,
                        "title":  "销售与点餐",
                        "sections":  [
                                         {
                                             "id":  "sales-upgrade",
                                             "title":  "销售方式升级",
                                             "content":  [
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "社区店",
                                                                                 "商场新店型"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "遇到熟客：称呼其姓氏先生/小姐，询问是否照旧",
                                                                                  "主动迎宾：顾客走近即微笑招呼"
                                                                              ],
                                                                              [
                                                                                  "堂食单量较稳定",
                                                                                  "快节奏作战：抓住黄金 30 秒推荐"
                                                                              ],
                                                                              [
                                                                                  "熟客为主，无需过多介绍",
                                                                                  "陌生客流为主：很多人第一次听说「苍井寿司」"
                                                                              ]
                                                                          ]
                                                             },
                                                             {
                                                                 "type":  "callout",
                                                                 "text":  "核心理念：销售动作要前置，不是等问才答，而是主动开口推荐。"
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "sales-principles",
                                             "title":  "销售三原则：快 · 准 · 轻",
                                             "content":  [
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "原则",
                                                                                 "含义",
                                                                                 "执行要点"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "快速响应",
                                                                                  "顾客进店 5 秒内必须有人接待，抢占注意力的黄金时间",
                                                                                  "看到顾客靠近展示柜立即上前，主动开口：「您好，欢迎光临苍井寿司！」快速推荐爆款，不等对方提问"
                                                                              ],
                                                                              [
                                                                                  "精准推荐",
                                                                                  "根据时段和客群特点，推荐最可能成交的产品",
                                                                                  "午市 → 推「一人套餐」；晚市/周末 → 推「多人套餐」；见小孩 → 推儿童餐；见情侣 → 推拍照好看的套餐"
                                                                              ],
                                                                              [
                                                                                  "轻松无压",
                                                                                  "语气亲切自然，避免强行推销感，降低决策压力",
                                                                                  "不说「一定要买」「很划算别错过」，改用「这款很多人喜欢，可以试试看~」；配合微笑、点头，营造轻松氛围"
                                                                              ]
                                                                          ]
                                                             },
                                                             {
                                                                 "type":  "callout",
                                                                 "text":  "推荐话术参考：\n「您好！现在新品寿司限时尝鲜价 39 元任选 12 件，要不要来一份试试？」"
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "sales-order",
                                             "title":  "接受订单",
                                             "content":  [
                                                             {
                                                                 "type":  "bullet",
                                                                 "items":  [
                                                                               "提供给顾客点餐二维码或堂食餐牌，确保顾客填写必要的订餐信息，如称呼、联系方式、取餐时间等",
                                                                               "确认顾客的订餐要求，如寿司种类、数量、特殊要求等",
                                                                               "与顾客核对订单信息的准确性，并复核特殊要求"
                                                                           ]
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "sales-experience",
                                             "title":  "体验感即转化率",
                                             "content":  [
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "维度",
                                                                                 "要求"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "视觉",
                                                                                  "展示柜丰满、灯光聚焦"
                                                                              ],
                                                                              [
                                                                                  "听觉",
                                                                                  "热情招呼 + 快速响应"
                                                                              ],
                                                                              [
                                                                                  "触觉",
                                                                                  "包装精致、配件齐全"
                                                                              ]
                                                                          ]
                                                             }
                                                         ]
                                         }
                                     ]
                    },
                    {
                        "id":  "module-3",
                        "num":  3,
                        "title":  "备餐与出餐",
                        "sections":  [
                                         {
                                             "id":  "prep-workflow",
                                             "title":  "前后场联动作战机制",
                                             "content":  [
                                                             {
                                                                 "type":  "code",
                                                                 "text":  "订单来了 → 营业员报单 → 厨房收到后立即制作 → 制作完喊一声「出餐」 → 营业员核对打包 → 60秒内交付顾客"
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "prep-peak",
                                             "title":  "高峰期作战三大核心要求",
                                             "content":  [
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "要求",
                                                                                 "说明",
                                                                                 "执行动作"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "预判产能",
                                                                                  "不能等订单来了才开始做",
                                                                                  "午市前完成半成品备货（≥180 件）；展示柜提前摆满（≥360 件）；炸虾、饭团等耗时品提前准备"
                                                                              ],
                                                                              [
                                                                                  "高频补柜",
                                                                                  "顾客只买「看起来新鲜」的",
                                                                                  "每 30 分钟巡柜一次，展示柜不是早上摆一次就行，缺了马上补，保持丰满感，这是吸引顾客驻足的关键"
                                                                              ],
                                                                              [
                                                                                  "联动协作",
                                                                                  "一个人卡住，全队受影响",
                                                                                  "营业员报单清晰：「王者拼盘 1 个」；厨房听到后立刻响应喊「收到」，完成后喊「出餐」；打包区提前备好袋、筷、酱料，60 秒内交付"
                                                                              ]
                                                                          ]
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "prep-process",
                                             "title":  "备餐流程",
                                             "content":  [
                                                             {
                                                                 "type":  "bullet",
                                                                 "items":  [
                                                                               "将订单传递给厨房或相关工作人员",
                                                                               "根据顾客的要求和寿司种类准备食材，并确保食材的新鲜和卫生",
                                                                               "完成寿司制作后，将其放置在适当的容器中，并进行出餐"
                                                                           ]
                                                             }
                                                         ]
                                         }
                                     ]
                    },
                    {
                        "id":  "module-4",
                        "num":  4,
                        "title":  "交付标准",
                        "sections":  [
                                         {
                                             "id":  "delivery-principles",
                                             "title":  "套餐三原则：即买 · 即走",
                                             "content":  [
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "原则",
                                                                                 "含义",
                                                                                 "执行要点"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "即买即走",
                                                                                  "追求「买了就能走」，拒绝等待和复杂选择",
                                                                                  "套餐提前组合好，无需现场拼单；打包流程标准化，60 秒内交付"
                                                                              ],
                                                                              [
                                                                                  "外带包装精美",
                                                                                  "不易洒漏、方便边走边吃或办公室用餐",
                                                                                  "打包要检查好，必须所有盖子盖严实；配件齐全：筷子、芥辣酱油、纸巾一体化包装"
                                                                              ],
                                                                              [
                                                                                  "视觉驱动转化",
                                                                                  "好产品要「看得见」，用视觉刺激购买欲",
                                                                                  "展示柜产品摆放整齐、丰满，吸引度；展示柜内干净整洁，玻璃光亮"
                                                                              ]
                                                                          ]
                                                             },
                                                             {
                                                                 "type":  "callout",
                                                                 "text":  "最好的销售不是说服，顾客没时间挑，我们就把「刚好合适」摆在他眼前，让顾客一眼就想带走。"
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "delivery-process",
                                             "title":  "交付流程",
                                             "content":  [
                                                             {
                                                                 "type":  "bullet",
                                                                 "items":  [
                                                                               "核对订单的准确性，并核对顾客订单的登记内容与取餐资料是否一致",
                                                                               "如需配送请将订单交给配送员，并向其核对配送员取餐号",
                                                                               "若使用小程序外卖服务，请先发起配送并将外卖订单移交给外卖人员，确保订单顺利送达至顾客处"
                                                                           ]
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "delivery-pack",
                                             "title":  "打包标准",
                                             "content":  [
                                                             {
                                                                 "type":  "callout",
                                                                 "text":  "备注：单量显示几人餐，请遵循以下打包标准："
                                                             },
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "人份",
                                                                                 "配件"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "1 人份",
                                                                                  "1 双筷子、2 包酱油、1 包芥末、1 个酱油碟"
                                                                              ]
                                                                          ]
                                                             }
                                                         ]
                                         }
                                     ]
                    },
                    {
                        "id":  "module-5",
                        "num":  5,
                        "title":  "付款处理",
                        "sections":  [
                                         {
                                             "id":  "payment-process",
                                             "title":  "付款处理",
                                             "content":  [
                                                             {
                                                                 "type":  "bullet",
                                                                 "items":  [
                                                                               "根据顾客的付款方式，如会员支付、现金、或移动支付，收取餐品费用",
                                                                               "使用系统或收款工具处理付款，并提供收据或订单确认给顾客",
                                                                               "如果顾客有任何付款问题或需要找零，应提供准确的解答和帮助"
                                                                           ]
                                                             }
                                                         ]
                                         }
                                     ]
                    },
                    {
                        "id":  "module-6",
                        "num":  6,
                        "title":  "环境卫生",
                        "sections":  [
                                         {
                                             "id":  "hygiene-daily",
                                             "title":  "日常维护",
                                             "content":  [
                                                             {
                                                                 "type":  "bullet",
                                                                 "items":  [
                                                                               "及时清理用餐区域的桌面、椅子和地面，保持整洁",
                                                                               "确保餐具、调料和饮品供应充足，并定期补充",
                                                                               "处理垃圾，保持店面环境干净整洁",
                                                                               "如有需要，提供顾客服务和解答顾客疑问"
                                                                           ]
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "hygiene-checklist",
                                             "title":  "日常工作清单",
                                             "content":  [
                                                             {
                                                                 "type":  "bullet",
                                                                 "items":  [
                                                                               "擦拭展示柜玻璃，整理价格标签，确保平整清晰",
                                                                               "及时收拾客桌卫生，保持清洁",
                                                                               "补充餐具包、筷子、纸巾、芥末酱油包",
                                                                               "跟进外卖订单的取餐情况，及时回复平台消息",
                                                                               "及时补充展示柜的食品，保持丰满"
                                                                           ]
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "hygiene-qsc-clean",
                                             "title":  "清洁标准（QSC · Cleanliness）",
                                             "content":  [
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "区域",
                                                                                 "标准要求"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "展示柜",
                                                                                  "无指纹、无水汽、玻璃透亮"
                                                                              ],
                                                                              [
                                                                                  "地面",
                                                                                  "无饭粒、无油渍、无积水"
                                                                              ],
                                                                              [
                                                                                  "收银台",
                                                                                  "无杂物堆放，手机不外露"
                                                                              ],
                                                                              [
                                                                                  "酱料区",
                                                                                  "瓶身干净，盖子拧紧，无溢出"
                                                                              ]
                                                                          ]
                                                             },
                                                             {
                                                                 "type":  "callout",
                                                                 "text":  "顾客看不见我们的流程，但看得见：我们服务态度好不好？地板干不干净？产品是否新鲜？\nQSC 不是一张检查表，而是我们对每一位顾客的无声承诺。"
                                                             }
                                                         ]
                                         }
                                     ]
                    },
                    {
                        "id":  "module-7",
                        "num":  7,
                        "title":  "品质管理",
                        "sections":  [
                                         {
                                             "id":  "quality-qsc",
                                             "title":  "QSC · Quality（品质——吃得放心）",
                                             "content":  [
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "标准要求",
                                                                                 "执行动作",
                                                                                 "禁止行为"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "所有半成品寿司必须贴时间标签",
                                                                                  "使用统一标签纸标注「制作时间」；按「先进先出」原则摆放",
                                                                                  "无标签出品；超时继续售卖"
                                                                              ],
                                                                              [
                                                                                  "半成品 4 小时内未售出必须下架",
                                                                                  "11:00 做的手握，15:00 前必须撤柜；可提前进行促销及建议性销售",
                                                                                  "抱着「还能卖」的侥幸心理"
                                                                              ],
                                                                              [
                                                                                  "寿司出品温度控制在 26℃ 左右",
                                                                                  "避免温度过高，长时间导致食物变质；定期检查实物的状态",
                                                                                  "食物变质继续售卖"
                                                                              ]
                                                                          ]
                                                             }
                                                         ]
                                         }
                                     ]
                    },
                    {
                        "id":  "module-8",
                        "num":  8,
                        "title":  "客诉处理",
                        "sections":  [
                                         {
                                             "id":  "complaint-etiquette",
                                             "title":  "服务话术（QSC · Service）",
                                             "content":  [
                                                             {
                                                                 "type":  "table",
                                                                 "headers":  [
                                                                                 "场景",
                                                                                 "标准话术",
                                                                                 "目的"
                                                                             ],
                                                                 "rows":  [
                                                                              [
                                                                                  "迎宾",
                                                                                  "「您好，欢迎光临！」",
                                                                                  "建立第一好感"
                                                                              ],
                                                                              [
                                                                                  "点餐",
                                                                                  "「请问需要堂食还是外带？」",
                                                                                  "明确需求，提前准备"
                                                                              ],
                                                                              [
                                                                                  "打包",
                                                                                  "「这是您的餐点，请慢用。」",
                                                                                  "体现尊重与仪式感"
                                                                              ],
                                                                              [
                                                                                  "送客",
                                                                                  "「感谢光临，祝您用餐愉快！」",
                                                                                  "提升满意度，促进复购"
                                                                              ]
                                                                          ]
                                                             }
                                                         ]
                                         },
                                         {
                                             "id":  "complaint-principles",
                                             "title":  "客诉处理三原则",
                                             "content":  [
                                                             {
                                                                 "type":  "steps",
                                                                 "items":  [
                                                                               "第一时间上报店长，不擅自承诺",
                                                                               "不说：「我不知道」、「这不是我做的」",
                                                                               "回应话术：「非常抱歉给您带来不便，我马上为您反馈处理。」"
                                                                           ]
                                                             },
                                                             {
                                                                 "type":  "callout",
                                                                 "text":  "记住：顾客不是冲你发火，是冲「体验不好」发火——我们代表的是品牌态度。"
                                                             }
                                                         ]
                                         }
                                     ]
                    }
                ]
}
